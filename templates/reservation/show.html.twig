{% extends 'base.html.twig' %}

{% block title %}Reservation{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">Reservation</h1>
                <p class="mt-1 text-sm text-slate-400">Vue détaillée — audit-friendly.</p>
            </div>
            <div class="flex flex-wrap items-center gap-3">
                <a href="{{ path('app_reservation_index') }}" class="inline-flex items-center justify-center rounded-xl px-4 py-2 text-sm font-semibold text-slate-200 ring-1 ring-white/10 hover:bg-white/5 transition">
                    Back
                </a>
                <a href="{{ path('app_reservation_edit', {'id': reservation.id}) }}" class="inline-flex items-center justify-center rounded-xl bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/15 transition">
                    Edit
                </a>
                {{ include('reservation/_delete_form.html.twig') }}
            </div>
        </div>

        <div class="rounded-2xl border border-cyan-200/10 bg-ink-900/30 p-6 shadow-glow">
            <dl class="grid gap-5 sm:grid-cols-2">
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">ID</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ reservation.id }}</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Created</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ reservation.createdAt ? reservation.createdAt|date('Y-m-d') : '' }}</dd>
                </div>
            </dl>
        </div>
    </div>
{% endblock %}
