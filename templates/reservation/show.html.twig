{% extends 'base.html.twig' %}

{% block title %}Réservation #{{ reservation.id }}{% endblock %}

{% block body %}
<div class="reservation-detail">
    <h1>Réservation #{{ reservation.id }}</h1>
    <p><strong>Participant :</strong> {{ reservation.participant.firstName }} {{ reservation.participant.lastName }} ({{ reservation.participant.email }})</p>
    <p><strong>Événement :</strong> <a href="{{ path('app_events_show', { id: reservation.event.id }) }}">{{ reservation.event.title }}</a></p>
    <p><strong>Date de réservation :</strong> {{ reservation.createdAt|date('d/m/Y') }}</p>
    <p><a href="{{ path('app_reservations_index') }}">Retour à la liste</a></p>
</div>
{% endblock %}
