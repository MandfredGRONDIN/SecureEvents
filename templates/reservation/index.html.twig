{% extends 'base.html.twig' %}

{% block title %}Reservations{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">Reservations</h1>
                <p class="mt-1 text-sm text-slate-400">Vos réservations — événements auxquels vous êtes inscrit.</p>
            </div>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {% for reservation in reservations %}
                <article class="group relative overflow-hidden rounded-2xl border border-cyan-200/10 bg-ink-900/30 shadow-glow transition hover:shadow-glowStrong">
                    <div class="absolute inset-0 bg-gradient-to-br from-cyan-300/10 via-transparent to-violet-400/10 opacity-70"></div>
                    <div class="relative p-5">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <h2 class="font-display text-lg tracking-wide text-slate-50 truncate">
                                    {% if reservation.event %}
                                        {{ reservation.event.title }}
                                    {% else %}
                                        Événement supprimé
                                    {% endif %}
                                </h2>
                                {% if reservation.event and reservation.event.location %}
                                    <p class="mt-1 text-xs text-slate-400 truncate">{{ reservation.event.location }}</p>
                                {% endif %}
                            </div>
                            <div class="shrink-0">
                                <span class="inline-flex items-center gap-1.5 rounded-full bg-cyan-400/20 px-3 py-1 text-xs font-semibold text-cyan-100 ring-1 ring-cyan-300/40">
                                    <span class="h-2 w-2 rounded-full bg-cyan-300"></span>
                                    <span>Réservé</span>
                                </span>
                            </div>
                        </div>

                        <dl class="mt-4 grid grid-cols-2 gap-3 text-xs">
                            {% if reservation.event %}
                            <div class="rounded-xl border border-cyan-200/10 bg-black/10 p-3">
                                <dt class="font-semibold uppercase tracking-wider text-slate-400">Date event</dt>
                                <dd class="mt-1 text-slate-100">
                                    {{ reservation.event.startDate ? reservation.event.startDate|date('Y-m-d') : '—' }}
                                </dd>
                            </div>
                            <div class="rounded-xl border border-cyan-200/10 bg-black/10 p-3">
                                <dt class="font-semibold uppercase tracking-wider text-slate-400">Capacité</dt>
                                <dd class="mt-1 text-slate-100">{{ reservation.event.reservations|length }} / {{ reservation.event.maxCapacity }}</dd>
                            </div>
                            {% endif %}
                            <div class="col-span-2 rounded-xl border border-cyan-200/10 bg-black/10 p-3">
                                <dt class="font-semibold uppercase tracking-wider text-slate-400">Réservé le</dt>
                                <dd class="mt-1 text-slate-100">
                                    {{ reservation.createdAt ? reservation.createdAt|date('d/m/Y') : '—' }}
                                </dd>
                            </div>
                        </dl>

                        <div class="mt-5 flex items-center justify-between gap-3">
                            <span class="text-xs text-slate-500">#{{ reservation.id }}</span>
                            <div class="flex gap-2">
                                <a href="{{ path('app_reservation_show', {'id': reservation.id}) }}"
                                   class="rounded-lg px-3 py-2 text-xs font-semibold text-slate-200 ring-1 ring-white/10 hover:bg-white/5 transition">Voir</a>
                                {{ include('reservation/_delete_form.html.twig', { reservation: reservation, compact: true }) }}
                            </div>
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="sm:col-span-2 lg:col-span-3 overflow-hidden rounded-2xl border border-cyan-200/10 bg-ink-900/30 p-8 text-center text-slate-400 shadow-glow">
                    Aucune réservation. Réservez depuis la page d'un événement.
                </div>
            {% endfor %}
        </div>
    </div>
{% endblock %}
