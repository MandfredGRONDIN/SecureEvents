{% extends 'base.html.twig' %}

{% block title %}Edit Event{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">Edit event</h1>
                <p class="mt-1 text-sm text-slate-400">Mise à jour des métadonnées, capacité et publication.</p>
            </div>
            <div class="flex items-center gap-3">
                {{ include('event/_delete_form.html.twig') }}
            </div>
        </div>

        {{ include('event/_form.html.twig', {'button_label': 'Update'}) }}

        <a href="{{ path('app_event_index') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-300 hover:text-slate-100">
            <span class="font-display">←</span>
            <span>back to list</span>
        </a>
    </div>
{% endblock %}
