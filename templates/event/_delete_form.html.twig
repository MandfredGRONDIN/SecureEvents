<form method="post" action="{{ path('app_event_delete', {'id': event.id}) }}" onsubmit="return confirm('{{ 'app.event.delete_confirm'|trans|e('js') }}');" class="inline">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ event.id) }}">
    <button class="inline-flex items-center justify-center rounded-xl bg-rose-500/10 px-4 py-2 text-sm font-semibold text-rose-100 ring-1 ring-rose-300/20 hover:bg-rose-500/15 transition">
        {{ 'app.event.delete'|trans }}
    </button>
</form>
