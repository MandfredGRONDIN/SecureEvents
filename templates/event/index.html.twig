{% extends 'base.html.twig' %}

{% block title %}Event index{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">Events</h1>
                <p class="mt-1 text-sm text-slate-400">Gestion des événements, capacité, publication.</p>
            </div>
            <a href="{{ path('app_event_new') }}"
               class="inline-flex items-center gap-2 rounded-xl bg-cyan-400/15 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/25 shadow-glow hover:bg-cyan-400/20 hover:shadow-glowStrong transition">
                <span class="font-display">+</span>
                <span>Create event</span>
            </a>
        </div>

        <div class="overflow-hidden rounded-2xl border border-cyan-200/10 bg-ink-900/30 shadow-glow">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-cyan-200/10 text-sm">
                    <thead class="bg-ink-950/40">
                        <tr class="text-left text-xs font-semibold uppercase tracking-wider text-slate-400">
                            <th class="px-5 py-4">ID</th>
                            <th class="px-5 py-4">Title</th>
                            <th class="px-5 py-4">Start</th>
                            <th class="px-5 py-4">Location</th>
                            <th class="px-5 py-4">Capacity</th>
                            <th class="px-5 py-4">Published</th>
                            <th class="px-5 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-cyan-200/10">
                    {% for event in events %}
                        <tr class="hover:bg-white/3 transition">
                            <td class="px-5 py-4 text-slate-300">{{ event.id }}</td>
                            <td class="px-5 py-4">
                                <div class="font-semibold text-slate-100">{{ event.title }}</div>
                                {% if event.description %}
                                    <div class="mt-0.5 max-w-[52ch] truncate text-xs text-slate-400">{{ event.description }}</div>
                                {% endif %}
                            </td>
                            <td class="px-5 py-4 text-slate-300">{{ event.startDate ? event.startDate|date('Y-m-d') : '' }}</td>
                            <td class="px-5 py-4 text-slate-300">{{ event.location }}</td>
                            <td class="px-5 py-4 text-slate-300">{{ event.maxCapacity }}</td>
                            <td class="px-5 py-4">
                                {% if event.isPublished %}
                                    <span class="inline-flex items-center rounded-full bg-cyan-300/10 px-2.5 py-1 text-xs font-semibold text-cyan-100 ring-1 ring-cyan-300/20">Yes</span>
                                {% else %}
                                    <span class="inline-flex items-center rounded-full bg-slate-500/10 px-2.5 py-1 text-xs font-semibold text-slate-300 ring-1 ring-white/10">No</span>
                                {% endif %}
                            </td>
                            <td class="px-5 py-4">
                                <div class="flex justify-end gap-2">
                                    <a href="{{ path('app_event_show', {'id': event.id}) }}"
                                       class="rounded-lg px-3 py-2 text-xs font-semibold text-slate-200 ring-1 ring-white/10 hover:bg-white/5 transition">View</a>
                                    <a href="{{ path('app_event_edit', {'id': event.id}) }}"
                                       class="rounded-lg px-3 py-2 text-xs font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/10 transition">Edit</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="7" class="px-5 py-10 text-center text-slate-400">
                                No events found. <a class="text-cyan-200 hover:text-cyan-100 underline underline-offset-4" href="{{ path('app_event_new') }}">Create your first event</a>.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
