{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}
<div class="example-wrapper">
    <h1>Événements</h1>
    {% if events|length > 0 %}
        <ul>
            {% for event in events %}
                <li>
                    <a href="{{ path('app_events_show', { id: event.id }) }}">{{ event.title }}</a>
                    — {{ event.startDate|date('d/m/Y') }} — {{ event.location }}
                </li>
            {% endfor %}
        </ul>
    {% else %}
        <p>Aucun événement pour le moment.</p>
    {% endif %}
</div>
{% endblock %}
