{% extends 'base.html.twig' %}

{% block title %}Event index{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">{{ 'app.event.title'|trans }}</h1>
                <p class="mt-1 text-sm text-slate-400">{{ 'app.event.subtitle'|trans }}</p>
            </div>
            {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_event_new') }}"
               class="inline-flex items-center gap-2 rounded-xl bg-cyan-400/15 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/25 shadow-glow hover:bg-cyan-400/20 hover:shadow-glowStrong transition">
                <span class="font-display">+</span>
                <span>{{ 'app.event.create'|trans }}</span>
            </a>
            {% endif %}
        </div>

        {# Filtres de recherche #}
        <div class="rounded-2xl border border-cyan-200/10 bg-ink-900/30 p-4 shadow-glow">
            <form method="get" action="{{ path('app_event_index') }}" class="flex flex-wrap items-end gap-4">
                <div class="min-w-[12rem] flex-1">
                    <label for="filter-q" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">{{ 'app.filter.title'|trans }}</label>
                    <input type="text" id="filter-q" name="q" value="{{ filters.q|default('') }}"
                           placeholder="{{ 'app.filter.title_placeholder'|trans }}"
                           class="w-full rounded-lg border border-cyan-200/20 bg-ink-950 px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:border-cyan-400/50 focus:outline-none focus:ring-1 focus:ring-cyan-400/30">
                </div>
                <div>
                    <label for="filter-from" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">{{ 'app.filter.from_date'|trans }}</label>
                    <input type="date" id="filter-from" name="from_date" value="{{ filters.from_date|default('') }}"
                           class="rounded-lg border border-cyan-200/20 bg-ink-950 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400/50 focus:outline-none focus:ring-1 focus:ring-cyan-400/30">
                </div>
                <div>
                    <label for="filter-to" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">{{ 'app.filter.to_date'|trans }}</label>
                    <input type="date" id="filter-to" name="to_date" value="{{ filters.to_date|default('') }}"
                           class="rounded-lg border border-cyan-200/20 bg-ink-950 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400/50 focus:outline-none focus:ring-1 focus:ring-cyan-400/30">
                </div>
                <div class="min-w-[10rem]">
                    <label for="filter-location" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">{{ 'app.filter.location'|trans }}</label>
                    <input type="text" id="filter-location" name="location" value="{{ filters.location|default('') }}"
                           placeholder="{{ 'app.filter.location_placeholder'|trans }}"
                           class="w-full rounded-lg border border-cyan-200/20 bg-ink-950 px-3 py-2 text-sm text-slate-100 placeholder-slate-500 focus:border-cyan-400/50 focus:outline-none focus:ring-1 focus:ring-cyan-400/30">
                </div>
                {% if is_granted('ROLE_USER') %}
                <div>
                    <label for="filter-published" class="block text-xs font-semibold uppercase tracking-wider text-slate-400 mb-1">{{ 'app.filter.status'|trans }}</label>
                    <select id="filter-published" name="published"
                            class="rounded-lg border border-cyan-200/20 bg-ink-950 px-3 py-2 text-sm text-slate-100 focus:border-cyan-400/50 focus:outline-none focus:ring-1 focus:ring-cyan-400/30">
                        <option value="" {{ (filters.published|default('')) == '' ? 'selected' : '' }}>{{ 'app.filter.all'|trans }}</option>
                        <option value="1" {{ filters.published|default('') == '1' ? 'selected' : '' }}>{{ 'app.filter.published'|trans }}</option>
                        <option value="0" {{ filters.published|default('') == '0' ? 'selected' : '' }}>{{ 'app.filter.drafts'|trans }}</option>
                    </select>
                </div>
                {% endif %}
                <div class="flex gap-2">
                    <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-cyan-400/15 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/25 hover:bg-cyan-400/20 transition">
                        {{ 'app.filter.submit'|trans }}
                    </button>
                    <a href="{{ path('app_event_index') }}" class="inline-flex items-center justify-center rounded-xl px-4 py-2 text-sm font-semibold text-slate-300 ring-1 ring-white/10 hover:bg-white/5 transition">
                        {{ 'app.filter.reset'|trans }}
                    </a>
                </div>
            </form>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {% for event in events %}
                <article class="group relative overflow-hidden rounded-2xl border border-cyan-200/10 bg-ink-900/30 shadow-glow transition hover:shadow-glowStrong">
                    <div class="absolute inset-0 bg-gradient-to-br from-cyan-300/10 via-transparent to-violet-400/10 opacity-70"></div>
                    <div class="relative p-5">
                        <div class="flex items-start justify-between gap-3">
                            <div class="min-w-0">
                                <h2 class="font-display text-lg tracking-wide text-slate-50 truncate">
                                    {{ event.title }}
                                </h2>
                                {% if event.description %}
                                    <p class="mt-1 text-xs text-slate-400 max-w-[60ch]">
                                        <span class="block truncate">{{ event.description }}</span>
                                    </p>
                                {% endif %}
                            </div>
                            <div class="shrink-0">
                                {% if event.isPublished %}
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-400/20 px-3 py-1 text-xs font-semibold text-emerald-100 ring-1 ring-emerald-300/40 shadow-glowStrong">
                                        <span class="h-2 w-2 rounded-full bg-emerald-300 animate-pulse"></span>
                                        <span>{{ 'app.event.published'|trans }}</span>
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800/80 px-3 py-1 text-xs font-semibold text-slate-200 ring-1 ring-slate-500/50">
                                        <span class="h-2 w-2 rounded-full bg-slate-500"></span>
                                        <span>{{ 'app.event.draft'|trans }}</span>
                                    </span>
                                {% endif %}
                            </div>
                        </div>

                        <dl class="mt-4 grid grid-cols-2 gap-3 text-xs">
                            <div class="rounded-xl border border-cyan-200/10 bg-black/10 p-3">
                                <dt class="font-semibold uppercase tracking-wider text-slate-400">{{ 'app.event.start'|trans }}</dt>
                                <dd class="mt-1 text-slate-100">
                                    {{ event.startDate ? event.startDate|date('Y-m-d') : '' }}
                                </dd>
                            </div>
                            <div class="rounded-xl border border-cyan-200/10 bg-black/10 p-3">
                                <dt class="font-semibold uppercase tracking-wider text-slate-400">{{ 'app.event.capacity'|trans }}</dt>
                                <dd class="mt-1 text-slate-100">{{ event.reservations|length }} / {{ event.maxCapacity }}</dd>
                            </div>
                            <div class="col-span-2 rounded-xl border border-cyan-200/10 bg-black/10 p-3">
                                <dt class="font-semibold uppercase tracking-wider text-slate-400">{{ 'app.event.location'|trans }}</dt>
                                <dd class="mt-1 text-slate-100 truncate">{{ event.location }}</dd>
                            </div>
                            <div class="col-span-2 rounded-xl border border-cyan-200/10 bg-black/10 p-3">
                                <dt class="font-semibold uppercase tracking-wider text-slate-400">{{ 'app.event.creator'|trans }}</dt>
                                <dd class="mt-1 text-slate-100 truncate">
                                    {% if event.createdBy %}
                                        {{ event.createdBy.firstName }} {{ event.createdBy.lastName }}
                                        <span class="text-slate-500">({{ event.createdBy.email }})</span>
                                    {% else %}
                                        <span class="text-slate-500">—</span>
                                    {% endif %}
                                </dd>
                            </div>
                        </dl>

                        <div class="mt-5 flex items-center justify-between gap-3">
                            <span class="text-xs text-slate-500">#{{ event.id }}</span>
                            <div class="flex gap-2">
                                <a href="{{ path('app_event_show', {'id': event.id}) }}"
                                   class="rounded-lg px-3 py-2 text-xs font-semibold text-slate-200 ring-1 ring-white/10 hover:bg-white/5 transition">{{ 'app.event.view'|trans }}</a>
                                {% if is_granted('EVENT_EDIT', event) %}
                                <a href="{{ path('app_event_edit', {'id': event.id}) }}"
                                   class="rounded-lg px-3 py-2 text-xs font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/10 transition">{{ 'app.event.edit'|trans }}</a>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                </article>
            {% else %}
                <div class="sm:col-span-2 lg:col-span-3 overflow-hidden rounded-2xl border border-cyan-200/10 bg-ink-900/30 p-8 text-center text-slate-400 shadow-glow">
                    {{ 'app.event.no_events'|trans }}{% if is_granted('ROLE_USER') %} <a class="text-cyan-200 hover:text-cyan-100 underline underline-offset-4" href="{{ path('app_event_new') }}">{{ 'app.event.create_first'|trans }}</a>.{% endif %}
                </div>
            {% endfor %}
        </div>

        {# Pagination — uniquement si plus d'une page #}
        {% if total_pages > 1 %}
            <nav class="flex flex-wrap items-center justify-center gap-2 pt-4" aria-label="{{ 'pagination.label'|trans }}">
                {% set query_params = app.request.query.all|default({}) %}
                {% if current_page > 1 %}
                <a href="{{ path('app_event_index', query_params|merge({ page: current_page - 1 })) }}"
                   class="inline-flex items-center rounded-xl px-4 py-2 text-sm font-semibold text-slate-300 ring-1 ring-white/10 hover:bg-white/5 transition">
                    {{ 'pagination.prev'|trans }}
                </a>
                {% else %}
                <span class="inline-flex items-center rounded-xl px-4 py-2 text-sm font-semibold text-slate-500 ring-1 ring-white/10 opacity-60 cursor-not-allowed">{{ 'pagination.prev'|trans }}</span>
                {% endif %}
                <span class="rounded-xl border border-cyan-200/10 bg-ink-900/30 px-4 py-2 text-sm text-slate-300">
                    {{ 'pagination.page'|trans({ '%current%': current_page, '%total%': total_pages }) }}
                </span>
                {% if current_page < total_pages %}
                <a href="{{ path('app_event_index', query_params|merge({ page: current_page + 1 })) }}"
                   class="inline-flex items-center rounded-xl px-4 py-2 text-sm font-semibold text-slate-300 ring-1 ring-white/10 hover:bg-white/5 transition">
                    {{ 'pagination.next'|trans }}
                </a>
                {% else %}
                <span class="inline-flex items-center rounded-xl px-4 py-2 text-sm font-semibold text-slate-500 ring-1 ring-white/10 opacity-60 cursor-not-allowed">{{ 'pagination.next'|trans }}</span>
                {% endif %}
            </nav>
        {% endif %}
    </div>
{% endblock %}
