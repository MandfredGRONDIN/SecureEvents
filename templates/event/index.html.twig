{# Vue du dernier événement affiché sur la page /events #}
{% extends 'base.html.twig' %}

{% block title %}Événements - SecureEvents{% endblock %}

{% block body %}
    <main class="event-page">
        <h1>Dernier événement</h1>

        <article class="event-card">
            <h2>{{ event.name }}</h2>
            <p class="event-description">{{ event.description }}</p>

            <dl class="event-details">
                <dt>Lieu</dt>
                <dd>{{ event.location }}</dd>

                <dt>Début</dt>
                <dd>{{ event.startAt|date('d/m/Y à H:i') }}</dd>

                <dt>Fin</dt>
                <dd>{{ event.endAt|date('d/m/Y à H:i') }}</dd>

                <dt>Capacité</dt>
                <dd>{{ event.capacity }} places</dd>
            </dl>
        </article>
    </main>
{% endblock %}
