{% extends 'base.html.twig' %}

{% block title %}Event{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        {% for message in app.flashes('success') %}
            <div class="rounded-xl border border-emerald-400/20 bg-emerald-500/10 px-4 py-3 text-sm text-emerald-100">
                {{ message }}
            </div>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <div class="rounded-xl border border-red-400/20 bg-red-500/10 px-4 py-3 text-sm text-red-100">
                {{ message }}
            </div>
        {% endfor %}
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">Event</h1>
                <p class="mt-1 text-sm text-slate-400">Vue détaillée — inspection rapide.</p>
            </div>
            <div class="flex flex-wrap items-center gap-3">
                <a href="{{ path('app_event_index') }}" class="inline-flex items-center justify-center rounded-xl px-4 py-2 text-sm font-semibold text-slate-200 ring-1 ring-white/10 hover:bg-white/5 transition">
                    Back
                </a>
                {% if is_granted('EVENT_EDIT', event) %}
                <a href="{{ path('app_event_edit', {'id': event.id}) }}" class="inline-flex items-center justify-center rounded-xl bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/15 transition">
                    Edit
                </a>
                {{ include('event/_delete_form.html.twig') }}
                {% endif %}
            </div>
        </div>

        <div class="rounded-2xl border border-cyan-200/10 bg-ink-900/30 p-6 shadow-glow">
            <dl class="grid gap-5 sm:grid-cols-2">
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">ID</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ event.id }}</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Published</dt>
                    <dd class="mt-1">
                        {% if event.isPublished %}
                            <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-400/20 px-3 py-1 text-xs font-semibold text-emerald-100 ring-1 ring-emerald-300/40 shadow-glowStrong">
                                <span class="h-2 w-2 rounded-full bg-emerald-300 animate-pulse"></span>
                                <span>Yes</span>
                            </span>
                        {% else %}
                            <span class="inline-flex items-center gap-1.5 rounded-full bg-slate-800/80 px-3 py-1 text-xs font-semibold text-slate-200 ring-1 ring-slate-500/50">
                                <span class="h-2 w-2 rounded-full bg-slate-500"></span>
                                <span>No</span>
                            </span>
                        {% endif %}
                    </dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Title</dt>
                    <dd class="mt-1 text-base font-semibold text-slate-50">{{ event.title }}</dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Description</dt>
                    <dd class="mt-1 text-sm text-slate-200">{{ event.description }}</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Start date</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ event.startDate ? event.startDate|date('Y-m-d') : '' }}</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Location</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ event.location }}</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Capacité</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ event.reservations|length }} / {{ event.maxCapacity }}</dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Créateur</dt>
                    <dd class="mt-1 text-sm text-slate-100">
                        {% if event.createdBy %}
                            {{ event.createdBy.firstName }} {{ event.createdBy.lastName }}
                            <span class="text-slate-500">({{ event.createdBy.email }})</span>
                        {% else %}
                            <span class="text-slate-500">Non renseigné</span>
                        {% endif %}
                    </dd>
                </div>
            </dl>

            {# Réservation directe pour l'utilisateur connecté #}
            <div class="mt-8 border-t border-cyan-200/10 pt-6">
                {% if app.user %}
                    {% if userReservation is not null %}
                        <p class="text-sm text-slate-200 mb-3">Vous êtes inscrit à cet événement.</p>
                        <a href="{{ path('app_reservation_show', { id: userReservation.id }) }}" class="inline-flex items-center justify-center rounded-xl bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/15 transition">
                            Voir ma réservation
                        </a>
                    {% elseif canReserve %}
                        <p class="text-sm text-slate-200 mb-3">Réservez votre place pour cet événement.</p>
                        <form method="post" action="{{ path('app_event_reserve', { id: event.id }) }}" class="inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('event_reserve_' ~ event.id) }}">
                            <button type="submit" class="inline-flex items-center justify-center rounded-xl bg-emerald-500/20 px-4 py-2 text-sm font-semibold text-emerald-100 ring-1 ring-emerald-400/30 hover:bg-emerald-500/30 transition">
                                Réserver ma place
                            </button>
                        </form>
                    {% else %}
                        <p class="text-sm text-slate-500">Cet événement est complet. Aucune place disponible.</p>
                    {% endif %}
                {% else %}
                    <p class="text-sm text-slate-400 mb-3">Connectez-vous pour réserver une place.</p>
                    <a href="{{ path('app_login') }}" class="inline-flex items-center justify-center rounded-xl bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/15 transition">
                        Se connecter
                    </a>
                {% endif %}
            </div>

            {# Tous les utilisateurs qui participent à cet événement #}
            <div class="mt-8 border-t border-cyan-200/10 pt-6">
                <h2 class="text-sm font-semibold uppercase tracking-wider text-slate-400 mb-4">Participants inscrits ({{ event.reservations|length }} / {{ event.maxCapacity }})</h2>
                <p class="text-xs text-slate-500 mb-3">Tous les utilisateurs qui vont participer à cet événement.</p>
                {% if event.reservations|length > 0 %}
                    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
                        {% for reservation in event.reservations %}
                            <div class="rounded-xl border border-cyan-200/10 bg-black/10 p-4 shadow-glow">
                                <div class="font-medium {{ app.user and reservation.participant.id == app.user.id ? 'text-cyan-200' : 'text-slate-100' }}">{{ reservation.participant.firstName }} {{ reservation.participant.lastName }}</div>
                                <div class="mt-2 text-xs text-slate-500">Réservé le {{ reservation.createdAt ? reservation.createdAt|date('d/m/Y') : '—' }}</div>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <p class="text-sm text-slate-500">Aucun participant inscrit pour le moment.</p>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
