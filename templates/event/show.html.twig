{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
<div class="event-detail">
    <h1>{{ event.title }}</h1>
    <p><strong>Date :</strong> {{ event.startDate|date('d/m/Y') }}</p>
    <p><strong>Lieu :</strong> {{ event.location }}</p>
    <p><strong>Capacité max :</strong> {{ event.maxCapacity }}</p>
    <p><strong>Publié :</strong> {{ event.isPublished ? 'Oui' : 'Non' }}</p>
    {% if event.description %}
        <p>{{ event.description }}</p>
    {% endif %}
    <p><a href="{{ path('app_events_index') }}">Retour à la liste</a></p>
</div>
{% endblock %}
