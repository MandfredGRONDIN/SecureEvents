{% extends 'base.html.twig' %}

{% block title %}{{ 'app.security.reset_password_title'|trans }} — {{ 'app.brand.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-md">
    <div class="rounded-2xl border border-cyan-200/15 bg-ink-900/40 p-8 shadow-glow">
        <h1 class="font-display text-xl tracking-wide text-slate-100 mb-2">{{ 'app.security.reset_password_title'|trans }}</h1>
        <p class="text-sm text-slate-400 mb-6">{{ 'app.security.reset_password_help'|trans }}</p>

        {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
            {{ form_row(form.plainPassword.first) }}
            {{ form_row(form.plainPassword.second) }}
            <button type="submit" class="w-full rounded-lg bg-gradient-to-r from-neon-500/90 to-cyan-500/90 px-4 py-3 font-medium text-ink-950 shadow-glow transition hover:shadow-glowStrong focus:outline-none focus:ring-2 focus:ring-neon-400/40">
                {{ 'form.reset_password.submit'|trans }}
            </button>
        {{ form_end(form) }}

        <p class="mt-6 text-center text-sm text-slate-400">
            <a href="{{ path('app_login') }}" class="font-medium text-cyan-300 hover:text-cyan-200 underline underline-offset-2">{{ 'app.security.back_login'|trans }}</a>
        </p>
    </div>
</div>
{% endblock %}
