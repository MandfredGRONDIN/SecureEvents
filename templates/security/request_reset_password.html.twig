{% extends 'base.html.twig' %}

{% block title %}{{ 'app.security.forgot_password'|trans }} — {{ 'app.brand.name'|trans }}{% endblock %}

{% block body %}
<div class="mx-auto max-w-md">
    <div class="rounded-2xl border border-cyan-200/15 bg-ink-900/40 p-8 shadow-glow">
        <h1 class="font-display text-xl tracking-wide text-slate-100 mb-2">{{ 'app.security.forgot_password'|trans }}</h1>
        <p class="text-sm text-slate-400 mb-6">{{ 'app.security.forgot_password_help'|trans }}</p>

        {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
            {{ form_row(form.email) }}
            <div class="flex flex-wrap items-center gap-3">
                <button type="submit" class="rounded-lg bg-gradient-to-r from-neon-500/90 to-cyan-500/90 px-4 py-3 font-medium text-ink-950 shadow-glow transition hover:shadow-glowStrong focus:outline-none focus:ring-2 focus:ring-neon-400/40">
                    {{ 'form.request_reset.submit'|trans }}
                </button>
                <a href="{{ path('app_login') }}" class="rounded-lg px-4 py-3 text-sm font-medium text-slate-300 ring-1 ring-white/10 hover:bg-white/5 transition">
                    {{ 'app.event.back'|trans }}
                </a>
            </div>
        {{ form_end(form) }}

        <p class="mt-6 text-center text-sm text-slate-400">
            {{ 'app.security.no_account'|trans }}
            <a href="{{ path('app_register') }}" class="font-medium text-cyan-300 hover:text-cyan-200 underline underline-offset-2">{{ 'app.security.register'|trans }}</a>
        </p>
    </div>
</div>
{% endblock %}
