<div class="rounded-2xl border border-cyan-200/10 bg-ink-900/30 p-6 shadow-glow">
    {{ form_start(form) }}
        {{ form_widget(form) }}
        <div class="pt-2 flex flex-wrap items-center gap-3">
            <button class="inline-flex items-center justify-center rounded-xl bg-cyan-400/15 px-5 py-2.5 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/25 shadow-glow hover:bg-cyan-400/20 hover:shadow-glowStrong transition">
                {{ button_label|default('Save') }}
            </button>
            <a href="{{ path('app_user_index') }}" class="inline-flex items-center justify-center rounded-xl px-5 py-2.5 text-sm font-semibold text-slate-200 ring-1 ring-white/10 hover:bg-white/5 transition">
                Cancel
            </a>
        </div>
    {{ form_end(form) }}
</div>
