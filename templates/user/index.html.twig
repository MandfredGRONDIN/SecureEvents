{% extends 'base.html.twig' %}

{% block title %}{{ 'app.user.title'|trans }}{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div>
            <h1 class="font-display text-2xl tracking-wide text-slate-50">{{ 'app.user.title'|trans }}</h1>
            <p class="mt-1 text-sm text-slate-400">{{ 'app.user.subtitle'|trans }}</p>
        </div>

        <div class="overflow-hidden rounded-2xl border border-cyan-200/10 bg-ink-900/30 shadow-glow">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-cyan-200/10 text-sm">
                    <thead class="bg-ink-950/40">
                        <tr class="text-left text-xs font-semibold uppercase tracking-wider text-slate-400">
                            <th class="px-5 py-4">{{ 'app.user.th_id'|trans }}</th>
                            <th class="px-5 py-4">{{ 'app.user.th_email'|trans }}</th>
                            <th class="px-5 py-4">{{ 'app.user.th_first_name'|trans }}</th>
                            <th class="px-5 py-4">{{ 'app.user.th_last_name'|trans }}</th>
                            <th class="px-5 py-4">{{ 'app.user.th_created_at'|trans }}</th>
                            <th class="px-5 py-4"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-cyan-200/10">
                    {% for user in users %}
                        <tr class="hover:bg-white/3 transition">
                            <td class="px-5 py-4 text-slate-300">{{ user.id }}</td>
                            <td class="px-5 py-4 text-slate-100">{{ user.email }}</td>
                            <td class="px-5 py-4 text-slate-300">{{ user.firstName }}</td>
                            <td class="px-5 py-4 text-slate-300">{{ user.lastName }}</td>
                            <td class="px-5 py-4 text-slate-300">{{ user.createdAt ? user.createdAt|date('Y-m-d') : '' }}</td>
                            <td class="px-5 py-4">
                                <a href="{{ path('app_user_show', { id: user.id }) }}" class="rounded-lg px-3 py-2 text-xs font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/10 transition">{{ 'app.event.view'|trans }}</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-5 py-10 text-center text-slate-400">{{ 'app.user.no_users'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
