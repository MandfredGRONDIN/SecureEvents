{% extends 'base.html.twig' %}

{% block title %}User index{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">Users</h1>
                <p class="mt-1 text-sm text-slate-400">Comptes, rôles et identités.</p>
            </div>
            <a href="{{ path('app_user_new') }}"
               class="inline-flex items-center gap-2 rounded-xl bg-cyan-400/15 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/25 shadow-glow hover:bg-cyan-400/20 hover:shadow-glowStrong transition">
                <span class="font-display">+</span>
                <span>Create user</span>
            </a>
        </div>

        <div class="overflow-hidden rounded-2xl border border-cyan-200/10 bg-ink-900/30 shadow-glow">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-cyan-200/10 text-sm">
                    <thead class="bg-ink-950/40">
                        <tr class="text-left text-xs font-semibold uppercase tracking-wider text-slate-400">
                            <th class="px-5 py-4">ID</th>
                            <th class="px-5 py-4">Email</th>
                            <th class="px-5 py-4">Roles</th>
                            <th class="px-5 py-4">Name</th>
                            <th class="px-5 py-4">Created</th>
                            <th class="px-5 py-4 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-cyan-200/10">
                    {% for user in users %}
                        <tr class="hover:bg-white/3 transition">
                            <td class="px-5 py-4 text-slate-300">{{ user.id }}</td>
                            <td class="px-5 py-4">
                                <div class="font-semibold text-slate-100">{{ user.email }}</div>
                                <div class="mt-0.5 text-xs text-slate-500">Password hidden</div>
                            </td>
                            <td class="px-5 py-4">
                                {% set roles = user.roles ? user.roles : [] %}
                                <div class="flex flex-wrap gap-2">
                                    {% if roles is empty %}
                                        <span class="inline-flex items-center rounded-full bg-slate-500/10 px-2.5 py-1 text-xs font-semibold text-slate-300 ring-1 ring-white/10">None</span>
                                    {% else %}
                                        {% for role in roles %}
                                            <span class="inline-flex items-center rounded-full bg-violet-400/10 px-2.5 py-1 text-xs font-semibold text-violet-100 ring-1 ring-violet-300/15">{{ role }}</span>
                                        {% endfor %}
                                    {% endif %}
                                </div>
                            </td>
                            <td class="px-5 py-4 text-slate-300">{{ user.firstName }} {{ user.lastName }}</td>
                            <td class="px-5 py-4 text-slate-300">{{ user.createdAt ? user.createdAt|date('Y-m-d') : '' }}</td>
                            <td class="px-5 py-4">
                                <div class="flex justify-end gap-2">
                                    <a href="{{ path('app_user_show', {'id': user.id}) }}"
                                       class="rounded-lg px-3 py-2 text-xs font-semibold text-slate-200 ring-1 ring-white/10 hover:bg-white/5 transition">View</a>
                                    <a href="{{ path('app_user_edit', {'id': user.id}) }}"
                                       class="rounded-lg px-3 py-2 text-xs font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/10 transition">Edit</a>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6" class="px-5 py-10 text-center text-slate-400">
                                No users found. <a class="text-cyan-200 hover:text-cyan-100 underline underline-offset-4" href="{{ path('app_user_new') }}">Create your first user</a>.
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>
{% endblock %}
