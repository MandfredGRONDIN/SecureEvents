{% extends 'base.html.twig' %}

{% block title %}User{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div class="flex flex-wrap items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">User</h1>
                <p class="mt-1 text-sm text-slate-400">Détails du compte — surface minimale, infos utiles.</p>
            </div>
            <div class="flex flex-wrap items-center gap-3">
                <a href="{{ path('app_user_index') }}" class="inline-flex items-center justify-center rounded-xl px-4 py-2 text-sm font-semibold text-slate-200 ring-1 ring-white/10 hover:bg-white/5 transition">
                    Back
                </a>
                <a href="{{ path('app_user_edit', {'id': user.id}) }}" class="inline-flex items-center justify-center rounded-xl bg-cyan-400/10 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/15 transition">
                    Edit
                </a>
                {{ include('user/_delete_form.html.twig') }}
            </div>
        </div>

        <div class="rounded-2xl border border-cyan-200/10 bg-ink-900/30 p-6 shadow-glow">
            <dl class="grid gap-5 sm:grid-cols-2">
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">ID</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ user.id }}</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Created</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ user.createdAt ? user.createdAt|date('Y-m-d') : '' }}</dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Email</dt>
                    <dd class="mt-1 text-sm font-semibold text-slate-50">{{ user.email }}</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">First name</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ user.firstName }}</dd>
                </div>
                <div>
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Last name</dt>
                    <dd class="mt-1 text-sm text-slate-100">{{ user.lastName }}</dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Roles</dt>
                    <dd class="mt-2 flex flex-wrap gap-2">
                        {% set roles = user.roles ? user.roles : [] %}
                        {% if roles is empty %}
                            <span class="inline-flex items-center rounded-full bg-slate-500/10 px-2.5 py-1 text-xs font-semibold text-slate-300 ring-1 ring-white/10">None</span>
                        {% else %}
                            {% for role in roles %}
                                <span class="inline-flex items-center rounded-full bg-violet-400/10 px-2.5 py-1 text-xs font-semibold text-violet-100 ring-1 ring-violet-300/15">{{ role }}</span>
                            {% endfor %}
                        {% endif %}
                    </dd>
                </div>
                <div class="sm:col-span-2">
                    <dt class="text-xs font-semibold uppercase tracking-wider text-slate-400">Password</dt>
                    <dd class="mt-1 text-sm text-slate-400">Hidden</dd>
                </div>
            </dl>
        </div>
    </div>
{% endblock %}
