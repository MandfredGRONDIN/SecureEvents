{% extends 'base.html.twig' %}

{% block title %}{{ 'app.admin.title'|trans }} — SecureEvents{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div>
            <h1 class="font-display text-2xl tracking-wide text-slate-50">{{ 'app.admin.title'|trans }}</h1>
            <p class="mt-1 text-sm text-slate-400">{{ 'app.admin.subtitle'|trans }}</p>
        </div>

        <div class="grid gap-4 sm:grid-cols-2">
            {% for entry in dashboard_entries %}
                <a href="{{ path(entry.route) }}"
                   class="group flex flex-col rounded-2xl border border-cyan-200/15 bg-ink-900/40 p-6 shadow-glow transition hover:border-cyan-200/25 hover:bg-ink-900/60 hover:shadow-glowStrong">
                    <span class="font-display text-lg font-semibold text-cyan-100 group-hover:text-cyan-50">
                        {{ entry.label_key|trans }}
                    </span>
                    <p class="mt-2 text-sm text-slate-400">
                        {{ entry.description_key|trans }}
                    </p>
                </a>
            {% endfor %}
        </div>
    </div>
{% endblock %}
