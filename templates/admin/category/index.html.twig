{% extends 'base.html.twig' %}

{% block title %}{{ 'app.category.title'|trans }} — {{ 'app.brand.name'|trans }}{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">{{ 'app.category.title'|trans }}</h1>
                <p class="mt-1 text-sm text-slate-400">{{ 'app.category.subtitle'|trans }}</p>
            </div>
            <a href="{{ path('app_admin_category_new') }}"
               class="inline-flex items-center gap-2 rounded-xl bg-cyan-400/15 px-4 py-2 text-sm font-semibold text-cyan-100 ring-1 ring-cyan-300/25 shadow-glow hover:bg-cyan-400/20 transition">
                <span class="font-display">+</span>
                <span>{{ 'app.category.new'|trans }}</span>
            </a>
        </div>

        <div class="overflow-hidden rounded-2xl border border-cyan-200/10 bg-ink-900/30 shadow-glow">
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-cyan-200/10 text-sm">
                    <thead class="bg-ink-950/40">
                        <tr class="text-left text-xs font-semibold uppercase tracking-wider text-slate-400">
                            <th class="px-5 py-4">{{ 'app.common.id'|trans }}</th>
                            <th class="px-5 py-4">{{ 'app.category.name'|trans }}</th>
                            <th class="px-5 py-4">{{ 'app.category.slug'|trans }}</th>
                            <th class="px-5 py-4">{{ 'app.category.events_count'|trans }}</th>
                            <th class="px-5 py-4"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-cyan-200/10">
                    {% for category in categories %}
                        <tr class="hover:bg-white/3 transition">
                            <td class="px-5 py-4 text-slate-300">{{ category.id }}</td>
                            <td class="px-5 py-4 text-slate-100">{{ category.name }}</td>
                            <td class="px-5 py-4 text-slate-400 font-mono text-xs">{{ category.slug }}</td>
                            <td class="px-5 py-4 text-slate-300">{{ category.events|length }}</td>
                            <td class="px-5 py-4">
                                <div class="flex items-center gap-2">
                                    <a href="{{ path('app_admin_category_edit', { id: category.id }) }}"
                                       class="rounded-lg px-3 py-2 text-xs font-semibold text-cyan-100 ring-1 ring-cyan-300/20 hover:bg-cyan-400/10 transition">{{ 'app.event.edit'|trans }}</a>
                                    {{ include('admin/category/_delete_form.html.twig', { category: category }) }}
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-5 py-10 text-center text-slate-400">{{ 'app.category.no_categories'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>

        <a href="{{ path('app_admin_index') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-300 hover:text-slate-100">
            <span class="font-display">←</span>
            <span>{{ 'app.event.back'|trans }}</span>
        </a>
    </div>
{% endblock %}
