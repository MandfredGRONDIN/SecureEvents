{% extends 'base.html.twig' %}

{% block title %}{{ 'app.category.edit_title'|trans }} — {{ 'app.brand.name'|trans }}{% endblock %}

{% block body %}
    <div class="flex flex-col gap-6">
        <div class="flex items-start justify-between gap-4">
            <div>
                <h1 class="font-display text-2xl tracking-wide text-slate-50">{{ 'app.category.edit_title'|trans }}</h1>
                <p class="mt-1 text-sm text-slate-400">{{ 'app.category.edit_subtitle'|trans }}</p>
            </div>
            {{ include('admin/category/_delete_form.html.twig', { category: category }) }}
        </div>

        <div class="rounded-2xl border border-cyan-200/10 bg-ink-900/30 p-6 shadow-glow max-w-md">
            {{ form_start(form, { attr: { class: 'space-y-5' } }) }}
                {{ form_row(form.name) }}
                <div class="flex flex-wrap items-center gap-3 pt-2">
                    <button type="submit"
                            class="rounded-lg bg-gradient-to-r from-neon-500/90 to-cyan-500/90 px-4 py-3 font-medium text-ink-950 shadow-glow transition hover:shadow-glowStrong focus:outline-none focus:ring-2 focus:ring-neon-400/40">
                        {{ 'form.button.save'|trans }}
                    </button>
                    <a href="{{ path('app_admin_category_index') }}" class="rounded-lg px-4 py-3 text-sm font-medium text-slate-300 ring-1 ring-white/10 hover:bg-white/5 transition">
                        {{ 'form.button.cancel'|trans }}
                    </a>
                </div>
            {{ form_end(form) }}
        </div>

        <a href="{{ path('app_admin_category_index') }}" class="inline-flex items-center gap-2 text-sm font-semibold text-slate-300 hover:text-slate-100">
            <span class="font-display">←</span>
            <span>{{ 'app.event.back_to_list'|trans }}</span>
        </a>
    </div>
{% endblock %}
