<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{{ 'email.reset.subject'|trans }}</title>
</head>
<body style="font-family: sans-serif; line-height: 1.5; color: #333;">
    <p>{{ 'email.reset.hello'|trans({ '%name%': user.firstName }) }},</p>
    <p>{{ 'email.reset.body'|trans }}</p>
    <p>
        <a href="{{ reset_url }}" style="display: inline-block; padding: 10px 20px; background: #0d9488; color: #fff; text-decoration: none; border-radius: 6px;">{{ 'email.reset.cta'|trans }}</a>
    </p>
    <p style="font-size: 0.9em; color: #666;">{{ 'email.reset.expiry'|trans({ '%hours%': expiry_hours }) }}</p>
    <p style="font-size: 0.85em; color: #999;">{{ 'email.reset.ignore'|trans }}</p>
</body>
</html>
